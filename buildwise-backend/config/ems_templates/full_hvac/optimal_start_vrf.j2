! ============================================================================
! Optimal Start EMS Template for VRF Systems
! VRF 시스템용 최적 기동/정지 제어
! ============================================================================

! --- Sensors ---
EnergyManagementSystem:Sensor,
    Zone_Temperature,        !- Name
    {{ zone_name | default('GF_Core') }},  !- Output:Variable or Output:Meter Index Key Name
    Zone Mean Air Temperature;  !- Output:Variable or Output:Meter Name

EnergyManagementSystem:Sensor,
    Outdoor_Temp,            !- Name
    Environment,             !- Output:Variable or Output:Meter Index Key Name
    Site Outdoor Air Drybulb Temperature;  !- Output:Variable or Output:Meter Name

! --- Actuators for VRF Outdoor Units ---
EnergyManagementSystem:Actuator,
    VRF_GF_Mode,             !- Name
    VRF_GF,                  !- Actuated Component Unique Name
    Variable Refrigerant Flow Heat Pump,  !- Actuated Component Type
    Operating Mode;          !- Actuated Component Control Type

EnergyManagementSystem:Actuator,
    VRF_MF_Mode,             !- Name
    VRF_MF,                  !- Actuated Component Unique Name
    Variable Refrigerant Flow Heat Pump,  !- Actuated Component Type
    Operating Mode;          !- Actuated Component Control Type

EnergyManagementSystem:Actuator,
    VRF_TF_Mode,             !- Name
    VRF_TF,                  !- Actuated Component Unique Name
    Variable Refrigerant Flow Heat Pump,  !- Actuated Component Type
    Operating Mode;          !- Actuated Component Control Type

! --- Global Variables ---
EnergyManagementSystem:GlobalVariable,
    Optimal_Start_Time,      !- Name
    Time_To_Setpoint,        !- Name
    VRF_Operating_Mode;      !- Name (0=Off, 1=Cooling, 2=Heating)

! --- Trend Variables ---
EnergyManagementSystem:TrendVariable,
    Zone_Temp_Trend,         !- Name
    Zone_Temperature,        !- EMS Variable Name
    96;                      !- Number of Timesteps (24hr at 15min)

! --- Program ---
EnergyManagementSystem:Program,
    VRF_Optimal_Start_Program,  !- Name
    ! Configuration
    SET TargetTime = {{ target_hour | default(9) }},
    SET CoolingSetpoint = {{ cooling_setpoint | default(26.0) }},
    SET HeatingSetpoint = {{ heating_setpoint | default(20.0) }},
    SET MaxStartAdvance = {{ max_start_advance | default(2.0) }},
    !
    ! Current time and day
    SET CurrentHour = Hour,
    SET CurrentDay = DayOfWeek,
    !
    ! Weekend check (1=Sunday, 7=Saturday)
    IF CurrentDay == 1 || CurrentDay == 7,
        SET VRF_GF_Mode = 0,
        SET VRF_MF_Mode = 0,
        SET VRF_TF_Mode = 0,
        RETURN,
    ENDIF,
    !
    ! Determine mode based on temperature
    IF Zone_Temperature > CoolingSetpoint + 1,
        SET TempDiff = Zone_Temperature - CoolingSetpoint,
        SET VRF_Operating_Mode = 1,  ! Cooling
    ELSEIF Zone_Temperature < HeatingSetpoint - 1,
        SET TempDiff = HeatingSetpoint - Zone_Temperature,
        SET VRF_Operating_Mode = 2,  ! Heating
    ELSE,
        SET TempDiff = 0,
        SET VRF_Operating_Mode = 0,  ! Off - in comfort zone
    ENDIF,
    !
    ! Calculate time to setpoint (simplified linear model)
    SET TempChangeRate = 1.5,  ! deg C/hour for VRF
    IF TempDiff > 0,
        SET Time_To_Setpoint = TempDiff / TempChangeRate,
    ELSE,
        SET Time_To_Setpoint = 0,
    ENDIF,
    !
    ! Limit start advance time
    IF Time_To_Setpoint > MaxStartAdvance,
        SET Time_To_Setpoint = MaxStartAdvance,
    ENDIF,
    !
    ! Calculate optimal start time
    SET Optimal_Start_Time = TargetTime - Time_To_Setpoint,
    !
    ! Control VRF systems - only force ON for early start
    SET ScheduleStartHour = 6,
    !
    IF CurrentHour >= Optimal_Start_Time && CurrentHour < ScheduleStartHour,
        ! Early start: force ON only if mode needed
        IF VRF_Operating_Mode > 0,
            SET VRF_GF_Mode = VRF_Operating_Mode,
            SET VRF_MF_Mode = VRF_Operating_Mode,
            SET VRF_TF_Mode = VRF_Operating_Mode,
        ELSE,
            SET VRF_GF_Mode = Null,
            SET VRF_MF_Mode = Null,
            SET VRF_TF_Mode = Null,
        ENDIF,
    ELSE,
        ! Normal operation: let schedule control
        SET VRF_GF_Mode = Null,
        SET VRF_MF_Mode = Null,
        SET VRF_TF_Mode = Null,
    ENDIF;

! --- Program Calling Manager ---
EnergyManagementSystem:ProgramCallingManager,
    VRF_Optimal_Start_Manager,  !- Name
    BeginTimestepBeforePredictor,  !- EnergyPlus Model Calling Point
    VRF_Optimal_Start_Program;  !- Program Name 1

! --- Output Variables ---
EnergyManagementSystem:OutputVariable,
    VRF Optimal Start Time,  !- Name
    Optimal_Start_Time,      !- EMS Variable Name
    Averaged,                !- Type of Data in Variable
    ZoneTimeStep;            !- Update Frequency

EnergyManagementSystem:OutputVariable,
    VRF Operating Mode,      !- Name
    VRF_Operating_Mode,      !- EMS Variable Name
    Averaged,                !- Type of Data in Variable
    ZoneTimeStep;            !- Update Frequency
