! ============================================================================
! M7: Full Optimization Normal (M6 + M4 = 외기냉방 + 부하제한 + 쾌적 보통)
! IdealLoadsAirSystem compatible — Zone Temperature Control actuators only
!
! Combined strategy (priority order):
! 1. Night pre-cooling: When OAT favorable at night
! 2. Peak load limiting: During peak hours (time-based, +2C)
! 3. OAT comfort adjustment: When OAT extreme (+1C/-1C, PMV 0.5)
! 4. OAT economizer: When OAT favorable for free cooling (-1C)
! 5. Peak comfort: During peak hours (+2C comfort relaxation)
! ============================================================================

! --- Sensors ---
EnergyManagementSystem:Sensor,
    M7_OAT_Sensor,
    Environment,
    Site Outdoor Air Drybulb Temperature;

{% for zone in zones %}
EnergyManagementSystem:Sensor,
    M7_{{ zone.name }}_Temp,
    {{ zone.name }},
    Zone Mean Air Temperature;

{% endfor %}

! --- Actuators ---
{% for zone in zones %}
EnergyManagementSystem:Actuator,
    M7_{{ zone.name }}_Cool_SP,
    {{ zone.name }},
    Zone Temperature Control,
    Cooling Setpoint;

EnergyManagementSystem:Actuator,
    M7_{{ zone.name }}_Heat_SP,
    {{ zone.name }},
    Zone Temperature Control,
    Heating Setpoint;

{% endfor %}

! --- Global Variables ---
EnergyManagementSystem:GlobalVariable,
    M7_Night_Precool,
    M7_Load_Limit,
    M7_Economizer,
    M7_Avg_Zone_Temp,
    M7_Cool_Offset,
    M7_Heat_Offset;

! --- Program ---
EnergyManagementSystem:Program,
    M7_Full_Normal_Program,
    ! Configuration
    SET CoolSP = {{ cooling_setpoint | default(24.0) }},
    SET HeatSP = {{ heating_setpoint | default(20.0) }},
    SET OccStart = {{ occupancy_start | default(9) }},
    SET OccEnd = {{ occupancy_end | default(18) }},
    SET NightCoolTarget = {{ night_cool_target | default(21.0) }},
    SET PeakStart = {{ peak_start_hour | default(14) }},
    SET PeakEnd = {{ peak_end_hour | default(17) }},
    SET OverrideTempLimit = {{ override_temp_limit | default(27) }},
    SET HighTempThreshold = 30,
    SET LowTempThreshold = 5,
    SET OAT_CoolAdj = {{ cooling_sp_adjustment | default(1.0) }},
    SET OAT_HeatAdj = {{ heating_sp_adjustment | default(-1.0) }},
    SET PeakCoolAdj = 2.0,
    !
    SET CurrentHour = Hour,
    SET CurrentDay = DayOfWeek,
    SET M7_Night_Precool = 0,
    SET M7_Load_Limit = 0,
    SET M7_Economizer = 0,
    SET M7_Cool_Offset = 0,
    SET M7_Heat_Offset = 0,
    !
    ! Weekend: schedule values
    IF CurrentDay == 1 || CurrentDay == 7,
{% for zone in zones %}
        SET M7_{{ zone.name }}_Cool_SP = NULL,
        SET M7_{{ zone.name }}_Heat_SP = NULL,
{% endfor %}
        RETURN,
    ENDIF,
    !
    ! Average zone temp
    SET M7_Avg_Zone_Temp = 0,
{% for zone in zones %}
    SET M7_Avg_Zone_Temp = M7_Avg_Zone_Temp + M7_{{ zone.name }}_Temp,
{% endfor %}
    SET M7_Avg_Zone_Temp = M7_Avg_Zone_Temp / {{ zones | length }},
    !
    ! === Night Pre-Cooling (22:00-06:00) ===
    IF (CurrentHour >= 22) || (CurrentHour < 6),
        IF M7_OAT_Sensor >= 15.0 && M7_OAT_Sensor <= 25.0,
            IF M7_OAT_Sensor < M7_Avg_Zone_Temp,
                SET M7_Night_Precool = 1,
{% for zone in zones %}
                SET M7_{{ zone.name }}_Cool_SP = NightCoolTarget,
                SET M7_{{ zone.name }}_Heat_SP = NULL,
{% endfor %}
                RETURN,
            ENDIF,
        ENDIF,
{% for zone in zones %}
        SET M7_{{ zone.name }}_Cool_SP = NULL,
        SET M7_{{ zone.name }}_Heat_SP = NULL,
{% endfor %}
        RETURN,
    ENDIF,
    !
    ! === Daytime Logic (stacking adjustments) ===
    !
    ! OAT comfort adjustment
    IF M7_OAT_Sensor > HighTempThreshold,
        SET M7_Cool_Offset = OAT_CoolAdj,
    ELSEIF M7_OAT_Sensor < LowTempThreshold,
        SET M7_Heat_Offset = OAT_HeatAdj,
    ENDIF,
    !
    ! Peak-hour adjustments
    IF CurrentHour >= PeakStart && CurrentHour < PeakEnd,
        ! Peak comfort relaxation
        SET M7_Cool_Offset = M7_Cool_Offset + PeakCoolAdj,
        SET M7_Load_Limit = 1,
    ENDIF,
    !
    ! OAT economizer (not during peak)
    IF M7_Load_Limit == 0,
        IF CurrentHour >= OccStart && CurrentHour < OccEnd,
            IF M7_OAT_Sensor >= 15.0 && M7_OAT_Sensor <= 26.0,
                IF M7_OAT_Sensor < M7_Avg_Zone_Temp,
                    SET M7_Economizer = 1,
                    SET M7_Cool_Offset = M7_Cool_Offset - 1.0,
                ENDIF,
            ENDIF,
        ENDIF,
    ENDIF,
    !
    ! === Apply setpoints ===
{% for zone in zones %}
    IF M7_Cool_Offset > 0,
        IF M7_{{ zone.name }}_Temp < OverrideTempLimit,
            SET M7_{{ zone.name }}_Cool_SP = CoolSP + M7_Cool_Offset,
        ELSE,
            SET M7_{{ zone.name }}_Cool_SP = NULL,
        ENDIF,
    ELSEIF M7_Cool_Offset < 0,
        SET M7_{{ zone.name }}_Cool_SP = CoolSP + M7_Cool_Offset,
    ELSE,
        SET M7_{{ zone.name }}_Cool_SP = NULL,
    ENDIF,
    IF M7_Heat_Offset < 0,
        SET M7_{{ zone.name }}_Heat_SP = HeatSP + M7_Heat_Offset,
    ELSE,
        SET M7_{{ zone.name }}_Heat_SP = NULL,
    ENDIF,
{% endfor %}
    ;

! --- Program Calling Manager ---
EnergyManagementSystem:ProgramCallingManager,
    M7_Full_Normal_Manager,
    BeginTimestepBeforePredictor,
    M7_Full_Normal_Program;

! --- Output Variables ---
EnergyManagementSystem:OutputVariable,
    M7 Night Precool,
    M7_Night_Precool,
    Averaged,
    ZoneTimeStep;

EnergyManagementSystem:OutputVariable,
    M7 Load Limit,
    M7_Load_Limit,
    Averaged,
    ZoneTimeStep;

EnergyManagementSystem:OutputVariable,
    M7 Cooling Offset,
    M7_Cool_Offset,
    Averaged,
    ZoneTimeStep;

EnergyManagementSystem:OutputVariable,
    M7 Heating Offset,
    M7_Heat_Offset,
    Averaged,
    ZoneTimeStep;
